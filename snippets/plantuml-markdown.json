{
  "PlantUML Empty Block": {
    "prefix": "plantuml",
    "body": [
      "```plantuml",
      "@startuml",
      "${0}",
      "@enduml",
      "```"
    ],
    "description": "Empty PlantUML code block"
  },
  "PlantUML Sequence Diagram": {
    "prefix": "plantuml-sequence",
    "body": [
      "```plantuml",
      "@startuml",
      "actor ${1:User} as user",
      "participant ${2:System} as system",
      "database ${3:Database} as db",
      "",
      "user -> system: ${4:Request}",
      "activate system",
      "",
      "opt Cache available",
      "  system --> user: Cached Response",
      "end",
      "",
      "system -> db: Query",
      "activate db",
      "db --> system: Result",
      "deactivate db",
      "",
      "== Processing ==",
      "",
      "par Async tasks",
      "  system -> system: Write audit log",
      "else",
      "  system -> db: Update stats",
      "end",
      "",
      "== Response ==",
      "",
      "alt Success",
      "  system --> user: 200 OK",
      "else Error",
      "  system --> user: 500 Error",
      "end",
      "",
      "deactivate system",
      "@enduml",
      "```"
    ],
    "description": "PlantUML sequence diagram block"
  },
  "PlantUML Class Diagram": {
    "prefix": "plantuml-class",
    "body": [
      "```plantuml",
      "@startuml",
      "abstract class ${1:Shape} {",
      "  #${2:x}: int",
      "  #${3:y}: int",
      "  +${4:area}(): double",
      "  +${5:draw}(): void",
      "}",
      "",
      "class ${6:Circle} {",
      "  -radius: double",
      "  +area(): double",
      "}",
      "",
      "class ${7:Rectangle} {",
      "  -width: double",
      "  -height: double",
      "  +area(): double",
      "}",
      "",
      "interface ${8:Drawable} {",
      "  +draw(): void",
      "  +resize(factor: double): void",
      "}",
      "",
      "${1:Shape} <|-- ${6:Circle}",
      "${1:Shape} <|-- ${7:Rectangle}",
      "${8:Drawable} <|.. ${1:Shape} : implements",
      "@enduml",
      "```"
    ],
    "description": "PlantUML class diagram block"
  },
  "PlantUML Activity Diagram": {
    "prefix": "plantuml-activity",
    "body": [
      "```plantuml",
      "@startuml",
      "start",
      ":${1:Receive Order};",
      "if (${2:In Stock}?) then (yes)",
      "  :${3:Pick Items};",
      "  fork",
      "    :Pack Box;",
      "  fork again",
      "    :Print Label;",
      "  end fork",
      "  :Ship Order;",
      "else (no)",
      "  :Notify Customer;",
      "  :Back Order;",
      "endif",
      ":Update Inventory;",
      "stop",
      "@enduml",
      "```"
    ],
    "description": "PlantUML activity diagram block"
  },
  "PlantUML Use Case Diagram": {
    "prefix": "plantuml-usecase",
    "body": [
      "```plantuml",
      "@startuml",
      "actor ${1:Customer} as customer",
      "actor ${2:Admin} as admin",
      "",
      "rectangle \"${3:Online Shop}\" {",
      "  usecase \"Browse Products\" as browse",
      "  usecase \"Place Order\" as order",
      "  usecase \"Make Payment\" as pay",
      "  usecase \"Manage Inventory\" as inventory",
      "}",
      "",
      "customer --> browse",
      "customer --> order",
      "order ..> pay : <<include>>",
      "admin --> inventory",
      "@enduml",
      "```"
    ],
    "description": "PlantUML use case diagram block"
  },
  "PlantUML Component Diagram": {
    "prefix": "plantuml-component",
    "body": [
      "```plantuml",
      "@startuml",
      "package \"${1:Frontend}\" {",
      "  [SPA] as spa",
      "  [Router]",
      "  [State Store]",
      "}",
      "",
      "package \"${2:Backend}\" {",
      "  [API Gateway]",
      "  [Auth Service]",
      "  [User Service]",
      "}",
      "",
      "package \"${3:Data}\" {",
      "  database \"PostgreSQL\" as pg",
      "  database \"Redis\" as redis",
      "}",
      "",
      "spa --> Router",
      "Router --> [State Store]",
      "spa --> [API Gateway] : REST",
      "[API Gateway] --> [Auth Service] : verify token",
      "[API Gateway] --> [User Service]",
      "[User Service] --> pg",
      "[Auth Service] --> redis : session",
      "@enduml",
      "```"
    ],
    "description": "PlantUML component diagram block"
  },
  "PlantUML State Diagram": {
    "prefix": "plantuml-state",
    "body": [
      "```plantuml",
      "@startuml",
      "[*] --> ${1:Idle}",
      "",
      "${1:Idle} --> ${2:Processing} : submit",
      "${2:Processing} --> ${3:Approved} : approve",
      "${2:Processing} --> ${4:Rejected} : reject",
      "${3:Approved} --> [*]",
      "${4:Rejected} --> ${1:Idle} : retry",
      "",
      "state ${2:Processing} {",
      "  [*] --> Validating",
      "  Validating --> Reviewing : valid",
      "  Validating --> [*] : invalid",
      "  Reviewing --> [*]",
      "}",
      "@enduml",
      "```"
    ],
    "description": "PlantUML state diagram block"
  },
  "PlantUML ER Diagram": {
    "prefix": "plantuml-er",
    "body": [
      "```plantuml",
      "@startuml",
      "entity ${1:User} {",
      "  *user_id : number <<PK>>",
      "  --",
      "  username : varchar",
      "  email : varchar",
      "  created_at : timestamp",
      "}",
      "",
      "entity ${2:Post} {",
      "  *post_id : number <<PK>>",
      "  --",
      "  *author_id : number <<FK>>",
      "  title : varchar",
      "  body : text",
      "  published : boolean",
      "}",
      "",
      "entity ${3:Comment} {",
      "  *comment_id : number <<PK>>",
      "  --",
      "  *post_id : number <<FK>>",
      "  *user_id : number <<FK>>",
      "  content : text",
      "  created_at : timestamp",
      "}",
      "",
      "${1:User} ||--o{ ${2:Post} : writes",
      "${2:Post} ||--o{ ${3:Comment} : has",
      "${1:User} ||--o{ ${3:Comment} : posts",
      "@enduml",
      "```"
    ],
    "description": "PlantUML entity-relationship diagram block"
  },
  "PlantUML Object Diagram": {
    "prefix": "plantuml-object",
    "body": [
      "```plantuml",
      "@startuml",
      "object ${1:Order} {",
      "  id = 1234",
      "  date = \"2026-03-09\"",
      "  status = \"shipped\"",
      "}",
      "",
      "object ${2:Customer} {",
      "  name = \"Alice\"",
      "  email = \"alice@example.com\"",
      "}",
      "",
      "object ${3:Item1} {",
      "  product = \"Keyboard\"",
      "  quantity = 1",
      "}",
      "",
      "object ${4:Item2} {",
      "  product = \"Mouse\"",
      "  quantity = 2",
      "}",
      "",
      "${2:Customer} --> ${1:Order} : places",
      "${1:Order} *-- ${3:Item1}",
      "${1:Order} *-- ${4:Item2}",
      "@enduml",
      "```"
    ],
    "description": "PlantUML object diagram block"
  },
  "PlantUML Deployment Diagram": {
    "prefix": "plantuml-deployment",
    "body": [
      "```plantuml",
      "@startuml",
      "node \"Load Balancer\" as lb",
      "",
      "node \"Web Server 1\" as web1 {",
      "  [Nginx]",
      "  [App]",
      "}",
      "",
      "node \"Web Server 2\" as web2 {",
      "  [Nginx] as nginx2",
      "  [App] as app2",
      "}",
      "",
      "cloud \"${1:AWS}\" {",
      "  database \"RDS\" as db",
      "  storage \"S3\" as s3",
      "}",
      "",
      "lb --> web1",
      "lb --> web2",
      "[App] --> db : JDBC",
      "app2 --> db : JDBC",
      "[App] --> s3 : upload",
      "@enduml",
      "```"
    ],
    "description": "PlantUML deployment diagram block"
  },
  "PlantUML Mindmap": {
    "prefix": "plantuml-mindmap",
    "body": [
      "```plantuml",
      "@startmindmap",
      "* ${1:Web Application}",
      "** ${2:Frontend}",
      "*** React",
      "*** TypeScript",
      "*** CSS Modules",
      "** ${3:Backend}",
      "*** Node.js",
      "*** Express",
      "*** REST API",
      "** ${4:Database}",
      "*** PostgreSQL",
      "*** Redis Cache",
      "** ${5:Infrastructure}",
      "*** Docker",
      "*** CI/CD",
      "*** AWS",
      "@endmindmap",
      "```"
    ],
    "description": "PlantUML mindmap block"
  },
  "PlantUML Gantt Chart": {
    "prefix": "plantuml-gantt",
    "body": [
      "```plantuml",
      "@startgantt",
      "Project starts ${1:2026-01-01}",
      "[${2:Design}] lasts 5 days",
      "[${3:Frontend Dev}] lasts 15 days",
      "[${4:Backend Dev}] lasts 12 days",
      "[${5:Testing}] lasts 8 days",
      "[${6:Deployment}] lasts 3 days",
      "",
      "[${3:Frontend Dev}] starts at [${2:Design}]'s end",
      "[${4:Backend Dev}] starts at [${2:Design}]'s end",
      "[${5:Testing}] starts at [${3:Frontend Dev}]'s end",
      "[${5:Testing}] starts at [${4:Backend Dev}]'s end",
      "[${6:Deployment}] starts at [${5:Testing}]'s end",
      "",
      "[${2:Design}] is colored in LightBlue",
      "[${5:Testing}] is colored in Salmon",
      "@endgantt",
      "```"
    ],
    "description": "PlantUML Gantt chart block"
  }
}
