{
  "Connection": {
    "prefix": "conn",
    "body": "${1:a} -> ${2:b}: ${3:label}",
    "description": "D2 connection"
  },
  "Component Diagram": {
    "prefix": "tmpl-comp",
    "body": [
      "${1:Frontend}: {",
      "  ${2:SPA}",
      "  ${3:Router}",
      "  ${4:State Store}",
      "",
      "  ${2:SPA} -> ${3:Router}",
      "  ${3:Router} -> ${4:State Store}",
      "}",
      "",
      "${5:Backend}: {",
      "  ${6:API Gateway}",
      "  ${7:Auth Service}",
      "  ${8:User Service}",
      "}",
      "",
      "${9:Data}: {",
      "  ${10:PostgreSQL}",
      "  ${11:Redis}",
      "}",
      "",
      "${1:Frontend}.${2:SPA} -> ${5:Backend}.${6:API Gateway}: REST",
      "${5:Backend}.${6:API Gateway} -> ${5:Backend}.${7:Auth Service}: verify token",
      "${5:Backend}.${6:API Gateway} -> ${5:Backend}.${8:User Service}",
      "${5:Backend}.${8:User Service} -> ${9:Data}.${10:PostgreSQL}",
      "${5:Backend}.${7:Auth Service} -> ${9:Data}.${11:Redis}: session"
    ],
    "description": "D2 component diagram"
  },
  "Sequence Diagram": {
    "prefix": "tmpl-seq",
    "body": [
      "shape: sequence_diagram",
      "",
      "${1:user}: ${2:User}",
      "${3:system}: ${4:System}",
      "${5:db}: ${6:Database}",
      "",
      "${1:user} -> ${3:system}: ${7:Request}",
      "${3:system} -> ${1:user}: Cached Response {",
      "  style.stroke-dash: 3",
      "}",
      "",
      "${3:system} -> ${5:db}: Query",
      "${5:db} -> ${3:system}: Result",
      "",
      "${3:system} -> ${3:system}: Write audit log",
      "${3:system} -> ${5:db}: Update stats",
      "",
      "${3:system} -> ${1:user}: 200 OK",
      "${3:system} -> ${1:user}: 500 Error {",
      "  style.stroke: \"#e74c3c\"",
      "}"
    ],
    "description": "D2 sequence diagram"
  },
  "Class": {
    "prefix": "tmpl-cls",
    "body": [
      "${1:BaseShape}: {",
      "  shape: class",
      "",
      "  # ${2:x}: int",
      "  # ${3:y}: int",
      "  + ${4:area}(): double",
      "  + ${5:draw}(): void",
      "}",
      "",
      "${6:Circle}: {",
      "  shape: class",
      "",
      "  - radius: double",
      "  + area(): double",
      "}",
      "",
      "${7:Rectangle}: {",
      "  shape: class",
      "",
      "  - width: double",
      "  - height: double",
      "  + area(): double",
      "}",
      "",
      "${8:Drawable}: {",
      "  shape: class",
      "",
      "  + draw(): void",
      "  + resize(factor double): void",
      "}",
      "",
      "${1:BaseShape} <-- ${6:Circle}: extends",
      "${1:BaseShape} <-- ${7:Rectangle}: extends",
      "${8:Drawable} <-- ${1:BaseShape}: implements {",
      "  style.stroke-dash: 3",
      "}"
    ],
    "description": "D2 class diagram"
  },
  "Grid": {
    "prefix": "tmpl-grid",
    "body": [
      "grid-rows: ${1:3}",
      "grid-columns: ${2:3}",
      "",
      "${3:Planning}: {",
      "  style.fill: \"${4:#e8f4fd}\"",
      "}",
      "${5:Design}: {",
      "  style.fill: \"${4:#e8f4fd}\"",
      "}",
      "${6:Prototype}: {",
      "  style.fill: \"${4:#e8f4fd}\"",
      "}",
      "${7:Frontend}: {",
      "  style.fill: \"${8:#fdf2e8}\"",
      "}",
      "${9:Backend}: {",
      "  style.fill: \"${8:#fdf2e8}\"",
      "}",
      "${10:Database}: {",
      "  style.fill: \"${8:#fdf2e8}\"",
      "}",
      "${11:Testing}: {",
      "  style.fill: \"${12:#e8fde8}\"",
      "}",
      "${13:Staging}: {",
      "  style.fill: \"${12:#e8fde8}\"",
      "}",
      "${14:Production}: {",
      "  style.fill: \"${12:#e8fde8}\"",
      "}"
    ],
    "description": "D2 grid layout"
  },
  "ER Diagram": {
    "prefix": "tmpl-er",
    "body": [
      "${1:User}: {",
      "  shape: sql_table",
      "  user_id: number {constraint: primary_key}",
      "  ${2:username}: varchar",
      "  ${3:email}: varchar",
      "  created_at: timestamp",
      "}",
      "",
      "${4:Post}: {",
      "  shape: sql_table",
      "  post_id: number {constraint: primary_key}",
      "  author_id: number {constraint: foreign_key}",
      "  title: varchar",
      "  body: text",
      "  published: boolean",
      "}",
      "",
      "${5:Comment}: {",
      "  shape: sql_table",
      "  comment_id: number {constraint: primary_key}",
      "  post_id: number {constraint: foreign_key}",
      "  user_id: number {constraint: foreign_key}",
      "  content: text",
      "  created_at: timestamp",
      "}",
      "",
      "${1:User}.user_id <-> ${4:Post}.author_id: writes",
      "${4:Post}.post_id <-> ${5:Comment}.post_id: has",
      "${1:User}.user_id <-> ${5:Comment}.user_id: posts"
    ],
    "description": "D2 ER diagram"
  },
  "Flow": {
    "prefix": "tmpl-flow",
    "body": [
      "${1:Start} -> ${2:Receive Order}",
      "${2:Receive Order} -> ${3:In Stock?}",
      "",
      "${3:In Stock?} -> ${4:Pick Items}: yes {",
      "  style.stroke: \"#27ae60\"",
      "}",
      "${4:Pick Items} -> ${5:Pack Box}",
      "${4:Pick Items} -> ${6:Print Label}",
      "${5:Pack Box} -> ${7:Ship Order}",
      "${6:Print Label} -> ${7:Ship Order}",
      "",
      "${3:In Stock?} -> ${8:Notify Customer}: no {",
      "  style.stroke: \"#e74c3c\"",
      "}",
      "${8:Notify Customer} -> ${9:Back Order}",
      "",
      "${7:Ship Order} -> ${10:Update Inventory}",
      "${9:Back Order} -> ${10:Update Inventory}",
      "${10:Update Inventory} -> ${11:End}"
    ],
    "description": "D2 flowchart"
  },
  "Icon Node": {
    "prefix": "icon",
    "body": [
      "${1:name}: {",
      "  icon: ${2:https://icons.terrastruct.com/essentials%2F112-server.svg}",
      "}"
    ],
    "description": "D2 node with icon"
  },
  "Markdown Node": {
    "prefix": "md",
    "body": [
      "${1:name}: |md",
      "  # ${2:Title}",
      "  ${3:Content}",
      "|"
    ],
    "description": "D2 Markdown text node"
  },
  "Tooltip": {
    "prefix": "tooltip",
    "body": [
      "${1:name}: {",
      "  tooltip: ${2:Hover text}",
      "  link: ${3:https://example.com}",
      "}"
    ],
    "description": "D2 tooltip and link"
  },
  "Layers": {
    "prefix": "layers",
    "body": [
      "layers: {",
      "  ${1:step1}: {",
      "    ${2:content}",
      "  }",
      "  ${3:step2}: {",
      "    ${4:content}",
      "  }",
      "}"
    ],
    "description": "D2 layers/steps"
  },
  "Style": {
    "prefix": "style",
    "body": [
      "style: {",
      "  fill: \"${1:#f0f0f0}\"",
      "  stroke: \"${2:#333}\"",
      "  border-radius: ${3:8}",
      "}"
    ],
    "description": "D2 custom style"
  },
  "Direction": {
    "prefix": "direction",
    "body": "direction: ${1|right,down,left,up|}",
    "description": "D2 layout direction"
  }
}
