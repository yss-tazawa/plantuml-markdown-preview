{
  "Flowchart": {
    "prefix": "tmpl-flow",
    "body": [
      "flowchart TD",
      "    Start([Start]) --> Receive[${1:Receive Order}]",
      "    Receive --> InStock{${2:In Stock}?}",
      "    InStock -->|Yes| Pick[${3:Pick Items}]",
      "    Pick --> Pack[Pack Box] & Label[Print Label]",
      "    Pack --> Ship[Ship Order]",
      "    Label --> Ship",
      "    InStock -->|No| Notify[Notify Customer]",
      "    Notify --> BackOrder[Back Order]",
      "    Ship --> Update[Update Inventory]",
      "    BackOrder --> Update",
      "    Update --> Stop([End])"
    ],
    "description": "Flowchart template"
  },
  "Sequence Diagram": {
    "prefix": "tmpl-seq",
    "body": [
      "sequenceDiagram",
      "    actor user as ${1:User}",
      "    participant system as ${2:System}",
      "    participant db as ${3:Database}",
      "",
      "    user->>+system: ${4:Request}",
      "",
      "    opt Cache available",
      "        system-->>user: Cached Response",
      "    end",
      "",
      "    system->>+db: Query",
      "    db-->>-system: Result",
      "",
      "    Note over user, db: Processing",
      "",
      "    par Async tasks",
      "        system->>system: Write audit log",
      "    and",
      "        system->>db: Update stats",
      "    end",
      "",
      "    Note over user, db: Response",
      "",
      "    alt Success",
      "        system-->>user: 200 OK",
      "    else Error",
      "        system-->>user: 500 Error",
      "    end",
      "",
      "    deactivate system"
    ],
    "description": "Sequence diagram template"
  },
  "Class Diagram": {
    "prefix": "tmpl-cls",
    "body": [
      "classDiagram",
      "    class ${1:Shape} {",
      "        <<abstract>>",
      "        #int x",
      "        #int y",
      "        +area() double",
      "        +draw() void",
      "    }",
      "",
      "    class ${2:Circle} {",
      "        -double radius",
      "        +area() double",
      "    }",
      "",
      "    class ${3:Rectangle} {",
      "        -double width",
      "        -double height",
      "        +area() double",
      "    }",
      "",
      "    class ${4:Drawable} {",
      "        <<interface>>",
      "        +draw() void",
      "        +resize(double factor) void",
      "    }",
      "",
      "    ${1:Shape} <|-- ${2:Circle}",
      "    ${1:Shape} <|-- ${3:Rectangle}",
      "    ${4:Drawable} <|.. ${1:Shape} : implements"
    ],
    "description": "Class diagram template"
  },
  "State Diagram": {
    "prefix": "tmpl-state",
    "body": [
      "stateDiagram-v2",
      "    [*] --> ${1:Idle}",
      "",
      "    ${1:Idle} --> ${2:Processing}: submit",
      "    ${2:Processing} --> ${3:Approved}: approve",
      "    ${2:Processing} --> ${4:Rejected}: reject",
      "    ${3:Approved} --> [*]",
      "    ${4:Rejected} --> ${1:Idle}: retry",
      "",
      "    state ${2:Processing} {",
      "        [*] --> Validating",
      "        Validating --> Reviewing: valid",
      "        Validating --> [*]: invalid",
      "        Reviewing --> [*]",
      "    }"
    ],
    "description": "State diagram template"
  },
  "ER Diagram": {
    "prefix": "tmpl-er",
    "body": [
      "erDiagram",
      "    ${1:USER} ||--o{ ${2:POST} : writes",
      "    ${2:POST} ||--o{ ${3:COMMENT} : has",
      "    ${1:USER} ||--o{ ${3:COMMENT} : posts",
      "",
      "    ${1:USER} {",
      "        number user_id PK",
      "        varchar username",
      "        varchar email",
      "        timestamp created_at",
      "    }",
      "    ${2:POST} {",
      "        number post_id PK",
      "        number author_id FK",
      "        varchar title",
      "        text body",
      "        boolean published",
      "    }",
      "    ${3:COMMENT} {",
      "        number comment_id PK",
      "        number post_id FK",
      "        number user_id FK",
      "        text content",
      "        timestamp created_at",
      "    }"
    ],
    "description": "ER diagram template"
  },
  "Gantt Chart": {
    "prefix": "tmpl-gantt",
    "body": [
      "gantt",
      "    title ${1:Project Plan}",
      "    dateFormat YYYY-MM-DD",
      "    section Design",
      "        ${2:Design}           :a1, ${3:2026-01-01}, 5d",
      "    section Development",
      "        ${4:Frontend Dev}     :b1, after a1, 15d",
      "        ${5:Backend Dev}      :b2, after a1, 12d",
      "    section Testing",
      "        ${6:Testing}          :c1, after b1, 8d",
      "    section Deployment",
      "        ${7:Deployment}       :d1, after c1, 3d"
    ],
    "description": "Gantt chart template"
  },
  "Pie Chart": {
    "prefix": "tmpl-pie",
    "body": [
      "pie title ${1:Language Usage}",
      "    \"${2:TypeScript}\" : ${3:45}",
      "    \"${4:JavaScript}\" : ${5:30}",
      "    \"${6:CSS}\" : ${7:15}",
      "    \"${8:Other}\" : ${9:10}"
    ],
    "description": "Pie chart template"
  },
  "Mindmap": {
    "prefix": "tmpl-mind",
    "body": [
      "mindmap",
      "    root((${1:Web Application}))",
      "        ${2:Frontend}",
      "            React",
      "            TypeScript",
      "            CSS Modules",
      "        ${3:Backend}",
      "            Node.js",
      "            Express",
      "            REST API",
      "        ${4:Database}",
      "            PostgreSQL",
      "            Redis Cache",
      "        ${5:Infrastructure}",
      "            Docker",
      "            CI/CD",
      "            AWS"
    ],
    "description": "Mindmap template"
  },
  "Timeline": {
    "prefix": "tmpl-timeline",
    "body": [
      "timeline",
      "    title ${1:Product Roadmap}",
      "    section ${2:Q1}",
      "        ${3:Jan} : ${4:Feature A} : ${5:Feature B}",
      "        ${6:Mar} : ${7:Feature C}",
      "    section ${8:Q2}",
      "        ${9:Apr} : ${10:Feature D}",
      "        ${11:Jun} : ${12:Feature E} : ${13:Feature F}"
    ],
    "description": "Timeline template"
  },
  "Git Graph": {
    "prefix": "tmpl-git",
    "body": [
      "gitGraph",
      "    commit",
      "    commit",
      "    branch ${1:feature}",
      "    checkout ${1:feature}",
      "    commit",
      "    commit",
      "    checkout main",
      "    merge ${1:feature}",
      "    commit"
    ],
    "description": "Git graph template"
  }
}
