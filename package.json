            "95%",
            "90%",
            "85%",
            "80%",
            "75%",
            "70%",
            "65%",
            "60%",
            "55%",
            "50%"
          ],
          "enumDescriptions": [
            "%configuration.mermaidScale.auto%",
            "%configuration.mermaidScale.100%",
            "%configuration.mermaidScale.95%",
            "%configuration.mermaidScale.90%",
            "%configuration.mermaidScale.85%",
            "%configuration.mermaidScale.80%",
