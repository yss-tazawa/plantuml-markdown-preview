{
  "name": "plantuml-markdown-preview",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.7.3",
  "license": "MIT",
  "publisher": "yss-tazawa",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.83.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "plantuml",
    "preview",
    "diagram",
    "uml",
    "svg",
    "png",
    "export",
    "html",
    "server",
    "java",
    "local",
    "mermaid",
    "d2",
    "pdf"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "plantuml",
        "aliases": [
          "PlantUML"
        ],
        "extensions": [
          ".puml",
          ".plantuml"
        ]
      },
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid"
        ],
        "extensions": [
          ".mmd",
          ".mermaid"
        ]
      },
      {
        "id": "d2",
        "aliases": [
          "D2"
        ],
        "extensions": [
          ".d2"
        ]
      }
    ],
    "grammars": [
      {
        "language": "plantuml",
        "scopeName": "source.plantuml",
        "path": "./syntaxes/plantuml.tmLanguage.json"
      },
      {
        "language": "mermaid",
        "scopeName": "source.mermaid",
        "path": "./syntaxes/mermaid.tmLanguage.json"
      },
      {
        "scopeName": "markdown.plantuml.codeblock",
        "path": "./syntaxes/plantuml.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.plantuml": "plantuml"
        }
      },
      {
        "scopeName": "markdown.mermaid.codeblock",
        "path": "./syntaxes/mermaid.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.mermaid": "mermaid"
        }
      },
      {
        "language": "d2",
        "scopeName": "source.d2",
        "path": "./syntaxes/d2.tmLanguage.json"
      },
      {
        "scopeName": "markdown.d2.codeblock",
        "path": "./syntaxes/d2.injection.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.d2": "d2"
        }
      }
    ],
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/plantuml-markdown.json"
      },
      {
        "language": "plantuml",
        "path": "./snippets/plantuml.json"
      },
      {
        "language": "markdown",
        "path": "./snippets/mermaid-markdown.json"
      },
      {
        "language": "mermaid",
        "path": "./snippets/mermaid.json"
      },
      {
        "language": "markdown",
        "path": "./snippets/d2-markdown.json"
      },
      {
        "language": "d2",
        "path": "./snippets/d2.json"
      }
    ],
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "plantuml-markdown-preview.openPreview",
        "title": "%command.openPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.openPumlPreview",
        "title": "%command.openPumlPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.openMermaidPreview",
        "title": "%command.openMermaidPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.openD2Preview",
        "title": "%command.openD2Preview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtml",
        "title": "%command.exportHtml.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtmlAndOpen",
        "title": "%command.exportHtmlAndOpen.title%",
        "category": "%command.category%"
