    "submenus": [
      {
        "id": "plantuml-markdown-preview.submenu",
        "label": "%submenu.label%"
      },
      {
        "id": "plantuml-markdown-preview.exportHtmlWidthSubmenu",
        "label": "%submenu.exportHtmlWidth.label%"
      },
      {
        "id": "plantuml-markdown-preview.exportHtmlWidthAndOpenSubmenu",
        "label": "%submenu.exportHtmlWidthAndOpen.label%"
      },
      {
        "id": "plantuml-markdown-preview.exportPdfSubmenu",
        "label": "%submenu.exportPdf.label%"
      },
      {
        "id": "plantuml-markdown-preview.exportPdfAndOpenSubmenu",
        "label": "%submenu.exportPdfAndOpen.label%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "plantuml-markdown-preview.submenu",
          "when": "resourceExtname == .md",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openPumlPreview",
          "when": "resourceExtname == .puml || resourceExtname == .plantuml",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openMermaidPreview",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openD2Preview",
          "when": "resourceExtname == .d2",
          "group": "plantuml-markdown-preview"
        }
      ],
      "editor/context": [
        {
          "submenu": "plantuml-markdown-preview.submenu",
          "when": "editorLangId == markdown",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.goToIncludeFile",
          "when": "editorLangId == plantuml && plantuml-markdown-preview.cursorOnIncludeLine",
          "group": "plantuml-markdown-preview@0"
        },
        {
          "command": "plantuml-markdown-preview.openPumlPreview",
          "when": "editorLangId == plantuml",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openMermaidPreview",
          "when": "editorLangId == mermaid",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openD2Preview",
          "when": "editorLangId == d2",
          "group": "plantuml-markdown-preview"
        }
      ],
      "editor/title": [
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlMarkdownPreview'",
          "group": "navigation"
        },
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlPumlPreview'",
          "group": "navigation"
        },
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlMermaidPreview'",
          "group": "navigation"
        },
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlD2Preview'",
          "group": "navigation"
        }
      ],
      "webview/context": [
        {
          "submenu": "plantuml-markdown-preview.exportHtmlWidthSubmenu",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "c_export@1"
        },
        {
          "submenu": "plantuml-markdown-preview.exportHtmlWidthAndOpenSubmenu",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "c_export@2"
        },
        {
          "submenu": "plantuml-markdown-preview.exportPdfSubmenu",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "e_pdf@1"
        },
        {
          "submenu": "plantuml-markdown-preview.exportPdfAndOpenSubmenu",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "e_pdf@2"
        },
        {
          "command": "plantuml-markdown-preview.openDiagramViewer",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "a_viewer@1"
        },
        {
          "command": "plantuml-markdown-preview.openIncludeSource",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram' && hasInclude",
          "group": "a_viewer@2"
        },
        {
          "command": "plantuml-markdown-preview.copyDiagramAsPng",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "b_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "f_save@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "f_save@1"
        },
        {
          "command": "plantuml-markdown-preview.exportAllDiagramsAsPng",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "g_bulk@1"
        },
        {
          "command": "plantuml-markdown-preview.exportAllDiagramsAsSvg",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "g_bulk@2"
        },
        {
          "command": "plantuml-markdown-preview.copyDiagramAsPng",
          "when": "webviewId == 'plantumlDiagramViewer'",
          "group": "b_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlDiagramViewer'",
          "group": "b_diagram@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlDiagramViewer'",
          "group": "b_diagram@3"
        },
        {
          "command": "plantuml-markdown-preview.copyDiagramAsPng",
          "when": "webviewId == 'plantumlPumlPreview'",
          "group": "b_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlPumlPreview'",
          "group": "b_diagram@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlPumlPreview'",
          "group": "b_diagram@3"
        },
        {
          "command": "plantuml-markdown-preview.copyDiagramAsPng",
          "when": "webviewId == 'plantumlMermaidPreview'",
          "group": "b_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlMermaidPreview'",
          "group": "b_diagram@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlMermaidPreview'",
          "group": "b_diagram@3"
        },
        {
          "command": "plantuml-markdown-preview.copyDiagramAsPng",
          "when": "webviewId == 'plantumlD2Preview'",
          "group": "b_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlD2Preview'",
          "group": "b_diagram@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlD2Preview'",
          "group": "b_diagram@3"
        }
      ],
      "plantuml-markdown-preview.submenu": [
        {
          "command": "plantuml-markdown-preview.goToIncludeFile",
          "when": "plantuml-markdown-preview.cursorOnIncludeLine",
          "group": "a_preview@0"
        },
        {
          "command": "plantuml-markdown-preview.openPreview",
          "group": "a_preview@1"
        },
        {
          "submenu": "plantuml-markdown-preview.exportHtmlWidthSubmenu",
          "group": "c_export@1"
        },
        {
          "submenu": "plantuml-markdown-preview.exportHtmlWidthAndOpenSubmenu",
          "group": "c_export@2"
        },
        {
          "submenu": "plantuml-markdown-preview.exportPdfSubmenu",
          "group": "e_pdf@1"
        },
        {
          "submenu": "plantuml-markdown-preview.exportPdfAndOpenSubmenu",
          "group": "e_pdf@2"
        },
        {
          "command": "plantuml-markdown-preview.exportAllDiagramsAsPng",
          "group": "f_bulk@1"
        },
        {
          "command": "plantuml-markdown-preview.exportAllDiagramsAsSvg",
          "group": "f_bulk@2"
        }
      ],
      "plantuml-markdown-preview.exportHtmlWidthSubmenu": [
        {
          "command": "plantuml-markdown-preview.exportHtmlCurrentSettings",
          "group": "0_current@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidth",
          "group": "1_width@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth640",
          "group": "1_width@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth768",
          "group": "1_width@3"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth960",
          "group": "1_width@4"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1024",
          "group": "1_width@5"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1200",
          "group": "1_width@6"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1440",
          "group": "1_width@7"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidthLeft",
          "group": "2_left@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth640Left",
          "group": "2_left@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth768Left",
          "group": "2_left@3"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth960Left",
          "group": "2_left@4"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1024Left",
          "group": "2_left@5"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1200Left",
          "group": "2_left@6"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1440Left",
          "group": "2_left@7"
        }
      ],
      "plantuml-markdown-preview.exportHtmlWidthAndOpenSubmenu": [
        {
          "command": "plantuml-markdown-preview.exportHtmlCurrentSettingsAndOpen",
          "group": "0_current@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidthAndOpen",
          "group": "1_width@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth640AndOpen",
          "group": "1_width@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth768AndOpen",
          "group": "1_width@3"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth960AndOpen",
          "group": "1_width@4"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1024AndOpen",
          "group": "1_width@5"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1200AndOpen",
          "group": "1_width@6"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1440AndOpen",
          "group": "1_width@7"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidthLeftAndOpen",
          "group": "2_left@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth640LeftAndOpen",
          "group": "2_left@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth768LeftAndOpen",
          "group": "2_left@3"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth960LeftAndOpen",
          "group": "2_left@4"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1024LeftAndOpen",
          "group": "2_left@5"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1200LeftAndOpen",
          "group": "2_left@6"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlWidth1440LeftAndOpen",
          "group": "2_left@7"
        }
      ],
      "plantuml-markdown-preview.exportPdfSubmenu": [
        {
          "command": "plantuml-markdown-preview.exportPdf",
          "group": "1_orientation@1"
        },
        {
          "command": "plantuml-markdown-preview.exportPdfLandscape",
          "group": "1_orientation@2"
        }
      ],
      "plantuml-markdown-preview.exportPdfAndOpenSubmenu": [
        {
          "command": "plantuml-markdown-preview.exportPdfAndOpen",
          "group": "1_orientation@1"
        },
        {
          "command": "plantuml-markdown-preview.exportPdfLandscapeAndOpen",
          "group": "1_orientation@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "plantuml-markdown-preview.openPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == markdown"
      },
      {
        "command": "plantuml-markdown-preview.openPumlPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == plantuml"
      },
      {
        "command": "plantuml-markdown-preview.openMermaidPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == mermaid"
      },
      {
        "command": "plantuml-markdown-preview.openD2Preview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == d2"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "plantumlMarkdownPreview.mode": {
          "order": 1,
          "type": "string",
          "default": "fast",
          "enum": [
            "fast",
            "secure",
            "easy"
          ],
          "enumDescriptions": [
            "%configuration.mode.fast%",
            "%configuration.mode.secure%",
            "%configuration.mode.easy%"
          ],
          "description": "%configuration.mode.description%"
        },
        "plantumlMarkdownPreview.javaPath": {
          "order": 2,
          "type": "string",
          "default": "java",
          "description": "%configuration.javaPath.description%"
        },
        "plantumlMarkdownPreview.plantumlJarPath": {
          "order": 3,
          "type": "string",
          "default": "",
          "description": "%configuration.plantumlJarPath.description%"
        },
        "plantumlMarkdownPreview.dotPath": {
          "order": 4,
          "type": "string",
          "default": "dot",
          "description": "%configuration.dotPath.description%"
        },
        "plantumlMarkdownPreview.plantumlIncludePath": {
          "order": 5,
          "type": "string",
          "default": "",
          "description": "%configuration.plantumlIncludePath.description%"
        },
        "plantumlMarkdownPreview.allowLocalImages": {
          "order": 6,
          "type": "string",
          "default": "mode-default",
          "enum": [
            "mode-default",
            "on",
            "off"
          ],
          "enumDescriptions": [
            "%configuration.allowLocalImages.mode-default%",
            "%configuration.allowLocalImages.on%",
            "%configuration.allowLocalImages.off%"
          ],
          "description": "%configuration.allowLocalImages.description%"
        },
        "plantumlMarkdownPreview.allowHttpImages": {
          "order": 7,
          "type": "boolean",
          "default": false,
          "description": "%configuration.allowHttpImages.description%"
        },
        "plantumlMarkdownPreview.previewTheme": {
          "order": 8,
          "type": "string",
          "default": "github-light",
          "enum": [
            "github-light",
            "atom-light",
            "one-light",
            "solarized-light",
            "vue",
            "pen-paper-coffee",
            "coy",
            "vs",
            "github-dark",
            "atom-dark",
            "one-dark",
            "dracula",
            "solarized-dark",
            "monokai"
          ],
          "enumDescriptions": [
            "%configuration.previewTheme.github-light%",
            "%configuration.previewTheme.atom-light%",
            "%configuration.previewTheme.one-light%",
            "%configuration.previewTheme.solarized-light%",
            "%configuration.previewTheme.vue%",
            "%configuration.previewTheme.pen-paper-coffee%",
            "%configuration.previewTheme.coy%",
            "%configuration.previewTheme.vs%",
            "%configuration.previewTheme.github-dark%",
            "%configuration.previewTheme.atom-dark%",
            "%configuration.previewTheme.one-dark%",
            "%configuration.previewTheme.dracula%",
            "%configuration.previewTheme.solarized-dark%",
            "%configuration.previewTheme.monokai%"
          ],
          "description": "%configuration.previewTheme.description%"
        },
        "plantumlMarkdownPreview.plantumlTheme": {
          "order": 9,
          "type": "string",
          "default": "default",
          "description": "%configuration.plantumlTheme.description%"
        },
        "plantumlMarkdownPreview.plantumlScale": {
          "order": 10,
          "type": "string",
          "default": "100%",
          "enum": [
            "auto",
            "120%",
            "115%",
            "110%",
            "105%",
            "100%",
            "95%",
            "90%",
            "85%",
            "80%",
            "75%",
            "70%"
          ],
          "enumDescriptions": [
            "%configuration.plantumlScale.auto%",
            "%configuration.plantumlScale.120%",
            "%configuration.plantumlScale.115%",
            "%configuration.plantumlScale.110%",
            "%configuration.plantumlScale.105%",
            "%configuration.plantumlScale.100%",
            "%configuration.plantumlScale.95%",
            "%configuration.plantumlScale.90%",
            "%configuration.plantumlScale.85%",
            "%configuration.plantumlScale.80%",
            "%configuration.plantumlScale.75%",
            "%configuration.plantumlScale.70%"
          ],
          "description": "%configuration.plantumlScale.description%"
        },
        "plantumlMarkdownPreview.mermaidTheme": {
          "order": 11,
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "dark",
            "forest",
            "neutral",
            "base"
          ],
          "enumDescriptions": [
            "%configuration.mermaidTheme.default%",
