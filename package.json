    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.83.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yss-tazawa/plantuml-markdown-preview"
  },
  "homepage": "https://github.com/yss-tazawa/plantuml-markdown-preview#readme",
  "bugs": {
