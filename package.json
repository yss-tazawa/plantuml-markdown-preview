{
  "name": "plantuml-markdown-preview",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "0.5.0",
  "license": "MIT",
  "publisher": "yss-tazawa",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.83.0"
  },
  "l10n": "./l10n",
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "markdown",
    "plantuml",
    "preview",
    "diagram",
    "uml",
    "svg",
    "png",
    "export",
    "html",
    "server",
    "java",
    "local",
    "mermaid",
    "pdf"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "plantuml",
        "aliases": ["PlantUML"],
        "extensions": [".puml", ".plantuml", ".pu"]
      },
      {
        "id": "mermaid",
        "aliases": ["Mermaid"],
        "extensions": [".mmd", ".mermaid"]
      }
    ],
    "markdown.markdownItPlugins": true,
    "commands": [
      {
        "command": "plantuml-markdown-preview.openPreview",
        "title": "%command.openPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.openPumlPreview",
        "title": "%command.openPumlPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.openMermaidPreview",
        "title": "%command.openMermaidPreview.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtml",
        "title": "%command.exportHtml.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtmlAndOpen",
        "title": "%command.exportHtmlAndOpen.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtmlFitToWidth",
        "title": "%command.exportHtmlFitToWidth.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportHtmlFitToWidthAndOpen",
        "title": "%command.exportHtmlFitToWidthAndOpen.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportPdf",
        "title": "%command.exportPdf.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.exportPdfAndOpen",
        "title": "%command.exportPdfAndOpen.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.changeTheme",
        "title": "%command.changeTheme.title%",
        "category": "%command.category%",
        "icon": "$(color-mode)"
      },
      {
        "command": "plantuml-markdown-preview.saveDiagramAsPng",
        "title": "%command.saveDiagramAsPng.title%",
        "category": "%command.category%"
      },
      {
        "command": "plantuml-markdown-preview.saveDiagramAsSvg",
        "title": "%command.saveDiagramAsSvg.title%",
        "category": "%command.category%"
      }
    ],
    "submenus": [
      {
        "id": "plantuml-markdown-preview.submenu",
        "label": "%submenu.label%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "plantuml-markdown-preview.submenu",
          "when": "resourceExtname == .md",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openPumlPreview",
          "when": "resourceExtname == .puml || resourceExtname == .plantuml || resourceExtname == .pu",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openMermaidPreview",
          "when": "resourceExtname == .mmd || resourceExtname == .mermaid",
          "group": "plantuml-markdown-preview"
        }
      ],
      "editor/context": [
        {
          "submenu": "plantuml-markdown-preview.submenu",
          "when": "editorLangId == markdown",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openPumlPreview",
          "when": "editorLangId == plantuml",
          "group": "plantuml-markdown-preview"
        },
        {
          "command": "plantuml-markdown-preview.openMermaidPreview",
          "when": "editorLangId == mermaid",
          "group": "plantuml-markdown-preview"
        }
      ],
      "editor/title": [
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlMarkdownPreview'",
          "group": "navigation"
        },
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlPumlPreview'",
          "group": "navigation"
        },
        {
          "command": "plantuml-markdown-preview.changeTheme",
          "when": "activeWebviewPanelId == 'plantumlMermaidPreview'",
          "group": "navigation"
        }
      ],
      "webview/context": [
        {
          "command": "plantuml-markdown-preview.exportHtml",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "2_export@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlAndOpen",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "2_export@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidth",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "3_export_fit@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidthAndOpen",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "3_export_fit@2"
        },
        {
          "command": "plantuml-markdown-preview.exportPdf",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "4_pdf@1"
        },
        {
          "command": "plantuml-markdown-preview.exportPdfAndOpen",
          "when": "webviewId == 'plantumlMarkdownPreview'",
          "group": "4_pdf@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlDiagramViewer'",
          "group": "1_save@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlDiagramViewer'",
          "group": "1_save@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "5_diagram@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlMarkdownPreview' && webviewSection == 'diagram'",
          "group": "5_diagram@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlPumlPreview'",
          "group": "1_save@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlPumlPreview'",
          "group": "1_save@2"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsPng",
          "when": "webviewId == 'plantumlMermaidPreview'",
          "group": "1_save@1"
        },
        {
          "command": "plantuml-markdown-preview.saveDiagramAsSvg",
          "when": "webviewId == 'plantumlMermaidPreview'",
          "group": "1_save@2"
        }
      ],
      "plantuml-markdown-preview.submenu": [
        {
          "command": "plantuml-markdown-preview.openPreview",
          "group": "1_preview@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtml",
          "group": "2_export@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlAndOpen",
          "group": "2_export@2"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidth",
          "group": "3_export_fit@1"
        },
        {
          "command": "plantuml-markdown-preview.exportHtmlFitToWidthAndOpen",
          "group": "3_export_fit@2"
        },
        {
          "command": "plantuml-markdown-preview.exportPdf",
          "group": "4_pdf@1"
        },
        {
          "command": "plantuml-markdown-preview.exportPdfAndOpen",
          "group": "4_pdf@2"
        }
      ]
    },
    "keybindings": [
      {
        "command": "plantuml-markdown-preview.openPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == markdown"
      },
      {
        "command": "plantuml-markdown-preview.openPumlPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == plantuml"
      },
      {
        "command": "plantuml-markdown-preview.openMermaidPreview",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "editorLangId == mermaid"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "plantumlMarkdownPreview.mode": {
          "order": 1,
          "type": "string",
          "default": "fast",
          "enum": [
            "fast",
            "secure",
            "easy"
          ],
          "enumDescriptions": [
            "%configuration.mode.fast%",
            "%configuration.mode.secure%",
            "%configuration.mode.easy%"
          ],
          "description": "%configuration.mode.description%"
        },
        "plantumlMarkdownPreview.javaPath": {
          "order": 2,
          "type": "string",
          "default": "java",
          "description": "%configuration.javaPath.description%"
        },
        "plantumlMarkdownPreview.plantumlJarPath": {
          "order": 3,
          "type": "string",
          "default": "",
          "description": "%configuration.plantumlJarPath.description%"
        },
        "plantumlMarkdownPreview.dotPath": {
          "order": 4,
          "type": "string",
          "default": "dot",
          "description": "%configuration.dotPath.description%"
        },
        "plantumlMarkdownPreview.allowLocalImages": {
          "order": 5,
          "type": "string",
          "default": "mode-default",
          "enum": [
            "mode-default",
            "on",
            "off"
          ],
          "enumDescriptions": [
            "%configuration.allowLocalImages.mode-default%",
            "%configuration.allowLocalImages.on%",
            "%configuration.allowLocalImages.off%"
          ],
          "description": "%configuration.allowLocalImages.description%"
        },
        "plantumlMarkdownPreview.allowHttpImages": {
          "order": 6,
          "type": "boolean",
          "default": false,
          "description": "%configuration.allowHttpImages.description%"
        },
        "plantumlMarkdownPreview.previewTheme": {
          "order": 7,
          "type": "string",
          "default": "github-light",
          "enum": [
            "github-light",
            "atom-light",
            "one-light",
            "solarized-light",
            "vue",
            "pen-paper-coffee",
            "coy",
            "vs",
            "github-dark",
            "atom-dark",
            "one-dark",
            "dracula",
            "solarized-dark",
            "monokai"
          ],
          "enumDescriptions": [
            "%configuration.previewTheme.github-light%",
            "%configuration.previewTheme.atom-light%",
            "%configuration.previewTheme.one-light%",
            "%configuration.previewTheme.solarized-light%",
            "%configuration.previewTheme.vue%",
            "%configuration.previewTheme.pen-paper-coffee%",
            "%configuration.previewTheme.coy%",
            "%configuration.previewTheme.vs%",
            "%configuration.previewTheme.github-dark%",
            "%configuration.previewTheme.atom-dark%",
            "%configuration.previewTheme.one-dark%",
            "%configuration.previewTheme.dracula%",
            "%configuration.previewTheme.solarized-dark%",
            "%configuration.previewTheme.monokai%"
          ],
          "description": "%configuration.previewTheme.description%"
        },
        "plantumlMarkdownPreview.plantumlTheme": {
          "order": 8,
          "type": "string",
          "default": "default",
          "description": "%configuration.plantumlTheme.description%"
        },
        "plantumlMarkdownPreview.plantumlScale": {
          "order": 9,
          "type": "string",
          "default": "100%",
          "enum": [
            "auto",
            "120%",
            "115%",
            "110%",
            "105%",
            "100%",
            "95%",
            "90%",
            "85%",
            "80%",
            "75%",
            "70%"
          ],
          "enumDescriptions": [
            "%configuration.plantumlScale.auto%",
            "%configuration.plantumlScale.120%",
            "%configuration.plantumlScale.115%",
            "%configuration.plantumlScale.110%",
            "%configuration.plantumlScale.105%",
            "%configuration.plantumlScale.100%",
            "%configuration.plantumlScale.95%",
            "%configuration.plantumlScale.90%",
            "%configuration.plantumlScale.85%",
            "%configuration.plantumlScale.80%",
            "%configuration.plantumlScale.75%",
            "%configuration.plantumlScale.70%"
          ],
          "description": "%configuration.plantumlScale.description%"
        },
        "plantumlMarkdownPreview.mermaidTheme": {
          "order": 10,
          "type": "string",
          "default": "default",
          "enum": [
            "default",
            "dark",
            "forest",
            "neutral",
            "base"
          ],
          "enumDescriptions": [
            "%configuration.mermaidTheme.default%",
            "%configuration.mermaidTheme.dark%",
            "%configuration.mermaidTheme.forest%",
            "%configuration.mermaidTheme.neutral%",
            "%configuration.mermaidTheme.base%"
          ],
          "description": "%configuration.mermaidTheme.description%"
        },
        "plantumlMarkdownPreview.mermaidScale": {
          "order": 11,
          "type": "string",
          "default": "80%",
          "enum": [
            "auto",
            "100%",
            "95%",
            "90%",
            "85%",
            "80%",
            "75%",
            "70%",
            "65%",
            "60%",
            "55%",
            "50%"
          ],
          "enumDescriptions": [
            "%configuration.mermaidScale.auto%",
            "%configuration.mermaidScale.100%",
            "%configuration.mermaidScale.95%",
            "%configuration.mermaidScale.90%",
            "%configuration.mermaidScale.85%",
            "%configuration.mermaidScale.80%",
            "%configuration.mermaidScale.75%",
            "%configuration.mermaidScale.70%",
            "%configuration.mermaidScale.65%",
            "%configuration.mermaidScale.60%",
            "%configuration.mermaidScale.55%",
            "%configuration.mermaidScale.50%"
          ],
          "description": "%configuration.mermaidScale.description%"
        },
        "plantumlMarkdownPreview.htmlMaxWidth": {
          "order": 12,
          "type": "string",
          "default": "960px",
          "enum": [
            "640px",
            "768px",
            "960px",
            "1024px",
            "1200px",
            "1440px",
            "none"
          ],
          "enumDescriptions": [
            "%configuration.htmlMaxWidth.640%",
            "%configuration.htmlMaxWidth.768%",
            "%configuration.htmlMaxWidth.960%",
            "%configuration.htmlMaxWidth.1024%",
            "%configuration.htmlMaxWidth.1200%",
            "%configuration.htmlMaxWidth.1440%",
            "%configuration.htmlMaxWidth.none%"
          ],
          "description": "%configuration.htmlMaxWidth.description%"
        },
        "plantumlMarkdownPreview.htmlAlignment": {
          "order": 13,
          "type": "string",
          "default": "center",
          "enum": [
            "center",
            "left"
          ],
          "enumDescriptions": [
            "%configuration.htmlAlignment.center%",
            "%configuration.htmlAlignment.left%"
          ],
          "description": "%configuration.htmlAlignment.description%"
        },
        "plantumlMarkdownPreview.enableMath": {
          "order": 14,
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableMath.description%"
        },
        "plantumlMarkdownPreview.debounceNoDiagramChangeMs": {
          "order": 15,
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "%configuration.debounceNoDiagramChangeMs.description%"
        },
        "plantumlMarkdownPreview.debounceDiagramChangeMs": {
          "order": 16,
          "type": [
            "number",
            "null"
          ],
          "default": null,
          "description": "%configuration.debounceDiagramChangeMs.description%"
        },
        "plantumlMarkdownPreview.plantumlLocalServerPort": {
          "order": 17,
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 65535,
          "description": "%configuration.plantumlLocalServerPort.description%"
        },
        "plantumlMarkdownPreview.plantumlServerUrl": {
          "order": 18,
          "type": "string",
          "default": "https://www.plantuml.com/plantuml",
          "description": "%configuration.plantumlServerUrl.description%"
        },
        "plantumlMarkdownPreview.enableDiagramViewer": {
          "order": 19,
          "type": "boolean",
          "default": true,
          "description": "%configuration.enableDiagramViewer.description%"
        },
        "plantumlMarkdownPreview.retainPreviewContext": {
          "order": 20,
          "type": "boolean",
          "default": true,
          "description": "%configuration.retainPreviewContext.description%"
        }
      }
    }
  },
  "dependencies": {
    "@traptitech/markdown-it-katex": "^3.6.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.16.35",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.12.3"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.83.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yss-tazawa/plantuml-markdown-preview"
  },
  "homepage": "https://github.com/yss-tazawa/plantuml-markdown-preview#readme",
  "bugs": {
    "url": "https://github.com/yss-tazawa/plantuml-markdown-preview/issues"
  },
  "scripts": {
    "build": "node esbuild.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p src/webview/tsconfig.webview.json",
    "package": "npm run typecheck && npm run build && npx @vscode/vsce package"
  }
}
