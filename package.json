          "description": "%configuration.d2Scale.description%"
        },
        "plantumlMarkdownPreview.htmlMaxWidth": {
          "order": 16,
          "type": "string",
          "default": "960px",
          "enum": [
            "640px",
            "768px",
            "960px",
            "1024px",
            "1200px",
            "1440px",
            "none"
          ],
          "enumDescriptions": [
            "%configuration.htmlMaxWidth.640%",
            "%configuration.htmlMaxWidth.768%",
            "%configuration.htmlMaxWidth.960%",
