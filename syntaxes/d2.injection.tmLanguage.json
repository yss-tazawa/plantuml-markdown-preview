{
  "scopeName": "markdown.d2.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "begin": "(^|\\G)(\\s*)(```)(d2)\\s*$",
      "end": "(^|\\G)(\\2)(```)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "contentName": "meta.embedded.block.d2",
      "patterns": [
        {
          "include": "source.d2"
        }
      ]
    }
  ]
}
